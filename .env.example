# Env vars use __ as the nested delimiter (pydantic-settings standard).
# Example: LLM__PROVIDER overrides settings.llm.provider
# Copy to .env and adjust values.

# ── LLM ────────────────────────────────────────────────────────────────────────
LLM__PROVIDER=llama_cpp                        # llama_cpp | ollama | mlx | vllm
LLM__MODEL_PATH=models/llm/qwen3-30b.gguf
LLM__CONTEXT_SIZE=32768
LLM__N_GPU_LAYERS=-1                           # -1 = all layers on Metal
LLM__DISABLE_DISK_CACHE=false                  # T-162 — true disables llama.cpp prompt cache

# ── Embeddings ─────────────────────────────────────────────────────────────────
EMBEDDINGS__PROVIDER=bge_m3                    # bge_m3 | nomic | qwen_embedding | openai | voyage | cohere | gemini
EMBEDDINGS__MODEL_PATH=models/embeddings/bge-m3
EMBEDDINGS__BATCH_SIZE=32
EMBEDDINGS__DEVICE=mps                         # mps | cuda | cpu

# API embedding providers (only required when EMBEDDINGS__PROVIDER matches)
EMBEDDINGS__OPENAI__API_KEY=
EMBEDDINGS__OPENAI__MODEL=text-embedding-3-large
EMBEDDINGS__VOYAGE__API_KEY=
EMBEDDINGS__VOYAGE__MODEL=voyage-large-2
EMBEDDINGS__COHERE__API_KEY=
EMBEDDINGS__COHERE__MODEL=embed-english-v3.0
EMBEDDINGS__GEMINI__API_KEY=
EMBEDDINGS__GEMINI__MODEL=text-embedding-004

# Embedding cache (Redis)
EMBEDDINGS__CACHE__ENABLED=false
EMBEDDINGS__CACHE__TTL_SECONDS=604800

# ── Redis ───────────────────────────────────────────────────────────────────────
REDIS__URL=redis://localhost:6379
REDIS__PASSWORD=

# ── Reranker ───────────────────────────────────────────────────────────────────
RERANKER__PROVIDER=bge_reranker
RERANKER__MODEL_PATH=models/rerankers/bge-reranker-v2-m3
RERANKER__TOP_K=10

# ── Vector DB ──────────────────────────────────────────────────────────────────
QDRANT__URL=http://localhost:6333
QDRANT__COLLECTION=rag_documents
QDRANT__API_KEY=

# ── Retrieval ──────────────────────────────────────────────────────────────────
RETRIEVAL__TOP_K_DENSE=50
RETRIEVAL__TOP_K_FINAL=5
RETRIEVAL__HYBRID_ALPHA=0.7
RETRIEVAL__HYBRID_FUSION=rrf
RETRIEVAL__BM25__BACKEND=memory             # memory (default) | disk (T-165 — large corpora)
# RETRIEVAL__BM25__DISK_PATH=data/processed/bm25_disk
# RETRIEVAL__BM25__SEGMENT_SIZE=10000

# Chunking + enrichment (disabled by default except strategy=recursive)
CHUNKING__STRATEGY=recursive              # recursive | semantic | parent_child | proposition
CHUNKING__PROPOSITION__QUALITY_THRESHOLD=7  # min score 1-10 per category when strategy=proposition (T-126)
CHUNKING__CONTEXTUAL_HEADERS__ENABLED=false
CHUNKING__CONTEXTUAL_HEADERS__EXCLUDE_FROM_LLM_CONTEXT=true
CHUNKING__AUGMENTATION__ENABLED=false
CHUNKING__AUGMENTATION__N_QUESTIONS=3

# ── Neo4j (Graph RAG) ──────────────────────────────────────────────────────────
NEO4J__ENABLED=false
NEO4J__URI=bolt://localhost:7687
NEO4J__USER=neo4j
NEO4J__PASSWORD=
NEO4J__DATABASE=neo4j
NEO4J__EXTRACT_ENTITIES_ON_INGEST=true

# ── Metadata store ─────────────────────────────────────────────────────────────
METADATA__ENABLED=true
METADATA__DB_PATH=data/processed/metadata.db

# ── API ────────────────────────────────────────────────────────────────────────
API__HOST=0.0.0.0
API__PORT=8000
API__RELOAD=true
API__API_KEY=                         # set to require X-API-Key on /ingest, /chat, /evals
API__MAX_UPLOAD_BYTES=10485760
API__RATE_LIMIT__ENABLED=false
API__RATE_LIMIT__REQUESTS_PER_MINUTE=60
API__RATE_LIMIT__BURST=10

# Feedback loop backend (T-146) — qdrant | redis | postgres
QUALITY__FEEDBACK_LOOP__EXPAND_CANDIDATE_POOL=true
QUALITY__FEEDBACK_LOOP__BACKEND=qdrant
QUALITY__FEEDBACK_LOOP__POSTGRES_URL=

# ── Multimodal parsing / OCR ───────────────────────────────────────────────────
# PARSING__LAYOUT_PARSER__ENABLED=false
# PARSING__TABLE_CHUNKS__ENABLED=false
# PARSING__FIGURE_ASSETS__ENABLED=false   # T-230 local figure asset store
# PARSING__FIGURE_ASSETS__STORE_DIR=data/assets
# PARSING__FIGURE_CAPTIONS__ENABLED=false # T-231 VLM captions (needs figure assets)
# PARSING__FIGURE_CAPTIONS__PROVIDER=openai  # openai | gemini
# PARSING__FIGURE_CAPTIONS__OPENAI__API_KEY=
# PARSING__FIGURE_CAPTIONS__OPENAI__MODEL=gpt-4o-mini
# PARSING__FIGURE_CAPTIONS__GEMINI__API_KEY=
# PARSING__FIGURE_CAPTIONS__GEMINI__MODEL=gemini-2.0-flash
# PARSING__OCR__ENABLED=false
# PARSING__OCR__PROVIDER=tesseract        # tesseract | easyocr | docling | azure_di
# PARSING__OCR__MIN_CHARS=50
# Azure Document Intelligence (when PARSING__OCR__PROVIDER=azure_di) — see docs/ocr-providers.md
# PARSING__OCR__AZURE_DI__ENDPOINT=https://<resource>.cognitiveservices.azure.com
# PARSING__OCR__AZURE_DI__API_KEY=

# ── Observability ──────────────────────────────────────────────────────────────
LOGGING__LEVEL=INFO
LOGGING__FORMAT=json
LOGGING__OTEL_ENDPOINT=http://localhost:4317
